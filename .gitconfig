[user]
	name = lijinlei
  email = lei4519@126.com

[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only --features=interactive

[include]
  path = ~/dotfiles/delta/themes.gitconfig

[delta]
  ; features = side-by-side decorations 
  ; theme: woolly-mammoth chameleon mellow-barbet
  features = decorations chameleon 
  navigate = true
  true-color = always

[delta "interactive"]
  keep-plus-minus-markers = false

[delta "decorations"]
  commit-decoration-style = blue ol
  commit-style = raw
  file-style = omit
  hunk-header-decoration-style = blue box
  hunk-header-file-style = red
  hunk-header-line-number-style = "#067a00"
  hunk-header-style = file line-number syntax


[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default

[pull]
  rebase = true
